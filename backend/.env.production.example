# ComHub Backend Production Environment Configuration
PORT=3000
NODE_ENV=production

# Supabase / Cloud Postgres Connection String
# Example: postgresql://postgres.xxxx:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# CORS Allowed Origin (e.g., https://your-comhub-frontend.vercel.app)
CORS_ORIGIN=https://comhub-frontend.vercel.app

# JWT Secret Key (Use a strong random 64-character secret in production)
JWT_SECRET=your_super_secret_production_jwt_key_min_64_chars_long
