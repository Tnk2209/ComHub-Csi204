# ComHub Backend Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database ---
# Local Postgres (dev): postgresql://postgres:password@localhost:5432/comhub
# Supabase Cloud (prod): postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://comhub_app:123456@localhost:5432/comhub

# --- JWT ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=3000
NODE_ENV=development

# --- CORS ---
# Vite dev server (default). Comma-separated list allowed.
CORS_ORIGIN=http://localhost:5173
